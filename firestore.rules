rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas de usuarios (solo el dueño puede acceder)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reglas para órdenes del usuario
    match /userOrders/{userId}/orders/{orderId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Reglas para simulaciones
    match /userSimulations/{userId}/simulations/{simulationId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Reglas para alertas de usuario
    match /userAlerts/{userId}/alerts/{alertId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Reglas para snapshots del balance diario
    match /userDailyBalances/{userId}/snapshots/{snapshotId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Bloquear todos los accesos no autorizados
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
